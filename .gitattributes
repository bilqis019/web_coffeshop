# Default: semua file dianggap text, Git atur otomatis line endings
* text=auto

# Pastikan file kode pakai LF (sesuai server Linux/hosting)
*.php     text eol=lf
*.js      text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.astro   text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.sql     text eol=lf
*.ts      text eol=lf
*.scss    text eol=lf

# File biner (gambar, font, dll) jangan diubah line endings
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
